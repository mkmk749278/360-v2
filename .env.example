# 360-Crypto-scalping-V2 — Docker deployment configuration
# Copy this file to .env and fill in your values before running: docker compose up -d

# Binance API (public endpoints only - no keys needed for market data)
BINANCE_REST_BASE=https://api.binance.com
BINANCE_WS_BASE=wss://stream.binance.com:9443/ws
BINANCE_FUTURES_REST_BASE=https://fapi.binance.com
BINANCE_FUTURES_WS_BASE=wss://fstream.binance.com/ws

# Binance API (required for authenticated endpoints)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=8410996204:AAEky7CKTx450C4aBdTeKlLqlnyfq4U6wPI

# --- Merged Telegram Channel (2-channel architecture, post-redesign) ---
# "Active Trading" channel receives: SCALP + SWING + SPOT + GEM signals
TELEGRAM_ACTIVE_CHANNEL_ID=-1003809706320

# Individual channel IDs (legacy — only needed if NOT using merged channel above)
TELEGRAM_SCALP_CHANNEL_ID=-1003809706320
TELEGRAM_SPOT_CHANNEL_ID=-1003626740685
TELEGRAM_FREE_CHANNEL_ID=-1003730302765
TELEGRAM_ADMIN_CHAT_ID=710718010
# TELEGRAM_SWING_CHANNEL_ID=-1003855571051  # now routed via TELEGRAM_ACTIVE_CHANNEL_ID
# TELEGRAM_GEM_CHANNEL_ID=-1003602049861    # now routed via TELEGRAM_ACTIVE_CHANNEL_ID

# Multiple admin IDs (comma-separated)
# TELEGRAM_ADMIN_IDS=123456789,987654321

# --- AI Sentiment APIs ---
# CryptoPanic (News Sentiment) - Get free key at https://cryptopanic.com/developers/api/
NEWS_API_KEY=f102d9cf805f57562b774083b60841bf464ab828
# LunarCrush (Social Sentiment) - Get free key at https://lunarcrush.com/developers
SOCIAL_SENTIMENT_API_KEY=57g1z0ucsjjfm13455axi6xacdmmoosuehfsoepdq
# Fear & Greed Index (free, no key needed)
FEAR_GREED_API_URL=https://api.alternative.me/fng/?limit=1

# --- OpenAI GPT-4 Trade Evaluator (optional) ---
# Get key at https://platform.openai.com/api-keys
# Leave blank to disable; signals still publish without AI evaluation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- On-Chain Intelligence (optional) ---
# Glassnode API key — https://glassnode.com/
# Leave blank to disable; confidence score uses neutral 5.0/10 fallback
ONCHAIN_API_KEY=

# Whale Alert (free tier) — https://whale-alert.io/
# Optional; expands whale tracking beyond BTC/ETH to all tokens
WHALE_ALERT_API_KEY=

# Etherscan (free tier, 5 calls/sec) — https://etherscan.io/apis
# Optional; used for ETH-specific whale wallet tracking
ETHERSCAN_API_KEY=

# Cornix auto-execution signal format (append Cornix block to SPOT/GEM/SWING signals)
# Set to true to enable: https://docs.cornix.io/signal-format
CORNIX_FORMAT_ENABLED=false

# Engine Settings
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_JSON=false
PAIR_FETCH_INTERVAL_HOURS=6
TOP_PAIRS_COUNT=50
SCAN_INTERVAL_SECONDS=1

# Redis (optional, for queue/cache persistence)
REDIS_URL=redis://localhost:6379/0

# Database (optional, for signal history persistence)
DATABASE_URL=

# Multi-exchange verification (optional)
# Bybit V5 public linear tickers — no API key required
SECOND_EXCHANGE_URL=https://api.bybit.com/v5/market/tickers?category=linear

# Circuit Breaker settings
CIRCUIT_BREAKER_MAX_CONSECUTIVE_SL=3
CIRCUIT_BREAKER_MAX_HOURLY_SL=5
CIRCUIT_BREAKER_MAX_DAILY_DRAWDOWN_PCT=10.0
CIRCUIT_BREAKER_COOLDOWN_SECONDS=900

# Signal scan cooldown (seconds per channel, after a signal fires)
SCALP_SCAN_COOLDOWN=300
SWING_SCAN_COOLDOWN=60
SPOT_SCAN_COOLDOWN=600

# Performance tracker persistence path
PERFORMANCE_TRACKER_PATH=data/signal_performance.json

# Max concurrent signals per channel.
# SCALP/SWING: capped for capital protection (leveraged trades).
# SPOT/GEM: effectively unlimited (999) — long hold durations (7–30 days).
#   Daily throttle comes from GEM_MAX_DAILY_SIGNALS in
#   the gem scanner, not from a concurrent-position cap.
MAX_SCALP_SIGNALS=5
MAX_SCALP_FVG_SIGNALS=3
MAX_SCALP_CVD_SIGNALS=3
MAX_SCALP_VWAP_SIGNALS=3
MAX_SCALP_OBI_SIGNALS=3
MAX_SWING_SIGNALS=10
MAX_SPOT_SIGNALS=999
MAX_GEM_SIGNALS=999

# Max signal hold duration per channel (seconds)
MAX_SCALP_HOLD=3600
MAX_SWING_HOLD=172800
MAX_SPOT_HOLD=604800
MAX_GEM_HOLD=2592000

# Thesis cooldown after SL (seconds per channel)
THESIS_COOLDOWN_SCALP=3600
THESIS_COOLDOWN_SWING=14400
THESIS_COOLDOWN_SPOT=3600
THESIS_COOLDOWN_GEM=604800

# Signal invalidation momentum threshold per channel
INVALIDATION_MOMENTUM_THRESHOLD_SCALP=0.10
INVALIDATION_MOMENTUM_THRESHOLD_SWING=0.20
INVALIDATION_MOMENTUM_THRESHOLD_SPOT=0.30
INVALIDATION_MOMENTUM_THRESHOLD_GEM=0.50

# Gem Scanner — daily/weekly candle seeding for ~1 year lookback
# Daily: ~365 candles for ATH drawdown, EMA, and 90-day volume averaging
# Weekly: ~52 candles for macro ATH detection from weekly highs
GEM_SEED_DAILY_CANDLES=365
GEM_SEED_WEEKLY_CANDLES=52

# Signal Lifecycle Monitor — background task that actively monitors every open
# SPOT, GEM, and SWING signal and posts human-readable updates to subscribers.
# Intervals are in seconds. SCALP is excluded (too short-lived for updates).
LIFECYCLE_CHECK_INTERVAL_SWING=14400   # 4 hours
LIFECYCLE_CHECK_INTERVAL_SPOT=21600    # 6 hours
LIFECYCLE_CHECK_INTERVAL_GEM=43200     # 12 hours

# Confidence drop thresholds (pts) that trigger YELLOW / RED alert levels.
LIFECYCLE_CONFIDENCE_DROP_YELLOW=15.0
LIFECYCLE_CONFIDENCE_DROP_RED=25.0
