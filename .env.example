# 360-Crypto-Scalping V2 — Configuration
# Copy this file to .env and fill in your values: cp .env.example .env
# Then deploy: sudo bash deploy_vps.sh

# ═══════════════════════════════════════════════════════════════════════
# REQUIRED — fill these in before deploying
# ═══════════════════════════════════════════════════════════════════════

# Telegram Bot — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Active Trading channel — the SINGLE channel that receives ALL signals
# To get channel ID: add @RawDataBot to the channel, it will print the chat ID
TELEGRAM_ACTIVE_CHANNEL_ID=ID:-1003711676922

# Admin chat — your personal Telegram chat ID (send /start to @userinfobot)
TELEGRAM_ADMIN_CHAT_ID=710718010

# Free channel (optional) — receives top 1–2 daily signals
TELEGRAM_FREE_CHANNEL_ID=ID:-1003782844881

# ═══════════════════════════════════════════════════════════════════════
# ENGINE MODE — Top-50 Futures-Only (recommended, low resource usage)
# ═══════════════════════════════════════════════════════════════════════

TOP50_FUTURES_ONLY=true
TOP50_FUTURES_COUNT=75
TOP50_UPDATE_INTERVAL_SECONDS=3600

# ═══════════════════════════════════════════════════════════════════════
# BINANCE API (public endpoints — no keys needed for market data)
# ═══════════════════════════════════════════════════════════════════════

BINANCE_REST_BASE=https://api.binance.com
BINANCE_WS_BASE=wss://stream.binance.com:9443/ws
BINANCE_FUTURES_REST_BASE=https://fapi.binance.com
BINANCE_FUTURES_WS_BASE=wss://fstream.binance.com/ws

# Binance API keys (optional — only needed for authenticated endpoints)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ═══════════════════════════════════════════════════════════════════════
# AI SENTIMENT APIs (optional — engine works without them at ~85% max)
# ═══════════════════════════════════════════════════════════════════════

# CryptoPanic (News Sentiment) — https://cryptopanic.com/developers/api/
NEWS_API_KEY=
# LunarCrush (Social Sentiment) — https://lunarcrush.com/developers
SOCIAL_SENTIMENT_API_KEY=
# Fear & Greed Index (free, no key needed)
FEAR_GREED_API_URL=https://api.alternative.me/fng/?limit=1

# OpenAI GPT-4 (optional macro evaluator) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# On-Chain Intelligence (optional) — https://glassnode.com/
ONCHAIN_API_KEY=

# ═══════════════════════════════════════════════════════════════════════
# ENGINE SETTINGS
# ═══════════════════════════════════════════════════════════════════════

LOG_LEVEL=INFO
LOG_DIR=logs
LOG_JSON=false
PAIR_FETCH_INTERVAL_HOURS=6
TOP_PAIRS_COUNT=50
SCAN_INTERVAL_SECONDS=1
SCAN_MIN_VOLUME_USD=1000000

# Redis (automatically configured in Docker — change only for bare-metal)
REDIS_URL=redis://localhost:6379/0

# Multi-exchange verification (optional, no key needed)
SECOND_EXCHANGE_URL=https://api.bybit.com/v5/market/tickers?category=linear

# Circuit Breaker — auto-pauses after consecutive losses
CIRCUIT_BREAKER_MAX_CONSECUTIVE_SL=3
CIRCUIT_BREAKER_MAX_HOURLY_SL=5
CIRCUIT_BREAKER_MAX_DAILY_DRAWDOWN_PCT=10.0
CIRCUIT_BREAKER_COOLDOWN_SECONDS=900

# Symbol blacklist — comma-separated symbols permanently excluded from scanning
SCAN_SYMBOL_BLACKLIST=XAUTUSDT,PAXGUSDT,MMTUSDT,KOMAUSDT,STOUSDT

# Scan cooldowns (seconds, per channel after a signal fires)
SCALP_SCAN_COOLDOWN=600

# Max concurrent signals
MAX_SCALP_SIGNALS=5
MAX_SCALP_FVG_SIGNALS=3
MAX_SCALP_CVD_SIGNALS=3
MAX_SCALP_VWAP_SIGNALS=3
MAX_SCALP_OBI_SIGNALS=3

# Max signal hold duration (seconds)
MAX_SCALP_HOLD=3600

# Thesis cooldown after SL (seconds)
THESIS_COOLDOWN_SCALP=3600

# Signal invalidation momentum threshold
INVALIDATION_MOMENTUM_THRESHOLD_SCALP=0.10

# Performance tracker persistence
PERFORMANCE_TRACKER_PATH=data/signal_performance.json

# ═══════════════════════════════════════════════════════════════════════
# SIGNAL QUALITY OVERHAUL — all controlled by env vars, zero code deleted
# ═══════════════════════════════════════════════════════════════════════

# Active channels (4 active, 4 soft-disabled — flip to true to re-enable)
CHANNEL_SCALP_ENABLED=true
CHANNEL_SCALP_FVG_ENABLED=true
CHANNEL_SCALP_ORDERBLOCK_ENABLED=true
CHANNEL_SCALP_DIVERGENCE_ENABLED=true
CHANNEL_SCALP_CVD_ENABLED=false
CHANNEL_SCALP_VWAP_ENABLED=false
CHANNEL_SCALP_SUPERTREND_ENABLED=false
CHANNEL_SCALP_ICHIMOKU_ENABLED=false

# Per-channel confidence thresholds
MIN_CONFIDENCE_SCALP=80
MIN_CONFIDENCE_FVG=78
MIN_CONFIDENCE_ORDERBLOCK=78
MIN_CONFIDENCE_DIVERGENCE=76

# ADX minimums
ADX_MIN_SCALP=20
ADX_MIN_FVG=18

# Hard gates
SMC_HARD_GATE_MIN=12.0
TREND_HARD_GATE_MIN=10.0

# Regime-aware volume floors (USD 24h)
VOL_FLOOR_TRENDING=3000000
VOL_FLOOR_VOLATILE=5000000
VOL_FLOOR_RANGING=1500000
VOL_FLOOR_QUIET=1000000
VOL_FLOOR_DEFAULT=2000000

# Global cross-channel symbol cooldown (seconds)
GLOBAL_SYMBOL_COOLDOWN_SECONDS=1800

# Correlated position cap
MAX_CORRELATED_SCALP_SIGNALS=4
